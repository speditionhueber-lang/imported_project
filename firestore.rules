
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function for admin accounts
    function isAdmin() {
      return request.auth != null && 
             request.auth.token.email in ['admin@example.com', 'office@spedition-hueber.at'];
    }

    // Allow logged-in users to read/write to the customers and inquiries collections
    match /customers/{document=**} {
      allow read, write: if request.auth != null;
    }
    
    match /inquiries/{document=**} {
       allow read, write: if request.auth != null;
    }

    match /phoneCallAnalyses/{document=**} {
       allow read, write: if request.auth != null;
    }
    
    match /scannedInvoices/{document=**} {
       allow read, write: if request.auth != null;
    }

    // Allow logged-in users to read and update their own CBM defaults
    match /cbm_defaults/{userId} {
      allow read, write: if request.auth != null;
    }
    
    // Allow users to manage their own todo lists and items
    match /todoLists/{listId} {
      allow read, create, update, delete: if request.auth != null && (resource == null || resource.data.owner == request.auth.uid);
    }

    match /todoLists/{listId}/todos/{todoId} {
       allow read, write: if request.auth != null && get(/databases/$(database)/documents/todoLists/$(listId)).data.owner == request.auth.uid;
    }

    // Default rule: Logged-in users can read and write everything else.
    // This is a flexible rule for the development phase to avoid permission errors.
    match /{path=**} {
      allow read, write: if request.auth != null;
    }
  }
}
